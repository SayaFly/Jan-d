$( document ).ready(function() {
  if(getCookie("theme-mode"))  {
    $("html").attr("data-theme", getCookie("theme-mode"));
  }

  $( ".alternaive-checkin" ).click(function() {
    var ablauf = new Date();
    var insiebenfTagen = ablauf.getTime() + (7 * 24 * 60 * 60 * 1000);
    ablauf.setTime(insiebenfTagen);
    document.cookie = "alternative-checkin=1; expires="+ablauf.toGMTString()+"; path=/";
  });

  $( ".theme-mode" ).click(function() {
    if($("html").attr("data-theme") == "light") {
      $("html").attr("data-theme", "dark");
      document.cookie = "theme-mode=dark; expires=0; path=/";

    }
    else if($("html").attr("data-theme") == "dark") {
      $("html").attr("data-theme", "light");
      document.cookie = "theme-mode=light; expires=0; path=/";
    }
  });

  const navMenu = document.querySelector('.main-nav-list__navigation');
  const navMenuActions = document.querySelector('.main-nav-list__actions');
  const navBurgerMenu = document.querySelector('.main-nav__burger-menu');

  $(navBurgerMenu).click(function() {
    toggleNavigation(navMenu, navBurgerMenu, navMenuActions);
  });

  var navItems = jQuery('.main-nav-list__item');

  navItems.click(function (e) {
    toggleNavigation(navMenu, navBurgerMenu, navMenuActions, "close");
  });

  $("#closeBackgroundMessage, .background-message__box-close").click(function() {
    $(".background-message").fadeOut();
  });
});

function toggleNavigation(navMenu, navBurgerMenu, navMenuActions, state=null) {
  if(state == "close") {
    $(navMenu).removeClass("main-nav-list__navigation--active");
    $(navMenuActions).removeClass("main-nav-list__actions--active");
    $(navBurgerMenu).removeClass("main-nav__burger-menu--active");
  }
  else {
    $(navMenu).toggleClass("main-nav-list__navigation--active");
    $(navMenuActions).toggleClass("main-nav-list__actions--active");
    $(navBurgerMenu).toggleClass("main-nav__burger-menu--active");
  }
}

