function getVerifyEmail() {
  $.get(window.location.origin + "/inc/klassen/get_verify_email.php", function(data, status){
    if(data == "already_verified") {
      Swal.fire({
        icon: 'error',
        title: 'Oops...',
        text: 'Du hast bereits deine E-Mail Adresse besätigt.'
      })
    }
    else if (data == "already_sent") {
      Swal.fire({
        icon: 'error',
        title: 'Oops...',
        text: 'Bitte warte eine Minute bevor erneut eine Anfrage absendest. Bitte überprüfe auch deine Spam- & Junk Posteingänge.',
        footer: '<a href="'+window.location.origin+'/einstellungen/account">E-Mail Adresse ändern?</a>'
      })
    }
    else if (data == "sent") {
      Swal.fire({
        icon: 'success',
        title: 'Versendet!',
        text: 'Du solltest in kürze eine E-Mail mit einem Bestätigungslink bekommen. Bitte überprüfe auch deine Spam- & Junk Posteingänge.',
        footer: '<a href="'+window.location.origin+'/einstellungen/account">E-Mail Adresse ändern?</a>'
      })
    }
  });
}

function getCookie(cname) {
  var name = cname + "=";
  var decodedCookie = decodeURIComponent(document.cookie);
  var ca = decodedCookie.split(';');
  for(var i = 0; i <ca.length; i++) {
    var c = ca[i];
    while (c.charAt(0) == ' ') {
      c = c.substring(1);
    }
    if (c.indexOf(name) == 0) {
      return c.substring(name.length, c.length);
    }
  }
  return "";
}
